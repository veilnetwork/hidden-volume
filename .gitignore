# Rust build artifacts.
/target

# Claude Code session data (this directory's prompts/state).
/.claude/

# Editor / IDE local config (do not commit per-developer settings).
.idea/
.vscode/

# Editor swap / backup files.
*.swp
*.swo
*.bak
*~

# OS-specific noise.
.DS_Store
Thumbs.db

# Local secrets / env. We never read these but contributors may
# stash them while debugging — keep them out of accidental commits.
.env
.env.*
!.env.example

# Per-target staging dirs from `scripts/release.sh`.
/dist/

# Per-developer scratch / "continue work" prompt notes. Not project
# documentation; tracked locally only. Untracked from the repo in
# pass-11 follow-up — stays on every developer's working copy as a
# bootstrap for `/loop` / "continue session" invocations.
/temp.md

# cargo-fuzz artifacts and per-target corpora.
crates/hidden-volume/fuzz/artifacts/
crates/hidden-volume/fuzz/corpus/
crates/hidden-volume/fuzz/target/
# The fuzz harness is a workspace-excluded bin crate; its lockfile is a
# build byproduct (regenerated by `cargo fuzz`), not a tracked source of
# truth like the root Cargo.lock. Keep it out of the tree.
crates/hidden-volume/fuzz/Cargo.lock

# uniffi-generated bindings (audit pass C4, 2026-05-03).
# ~11k lines of auto-generated source; regenerated locally via
# `bindings/README.md` § Regenerating. Kept tracked: bindings/README.md,
# bindings/python/test_smoke.py, bindings/python/.gitignore.
bindings/python/hidden_volume_ffi.py
bindings/python/libhidden_volume_ffi.*
bindings/kotlin/uniffi/
bindings/ruby/hidden_volume_ffi.rb
bindings/swift/hidden_volume_ffi.swift
bindings/swift/hidden_volume_ffiFFI.h
bindings/swift/hidden_volume_ffiFFI.modulemap
bindings/dart/hidden_volume_ffi.dart
